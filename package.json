{
  "name": "manhattan-vibes",
  "version": "0.1.0",
  "private": true,
  "description": "Manhattan Vibes restaurant ecosystem — monorepo",
  "workspaces": [
    "apps/api",
    "apps/admin",
    "apps/kds",
    "apps/web",
    "apps/pos",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace=@mv/api",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "infra:up": "docker compose -f docker-compose.yml up -d",
    "infra:down": "docker compose -f docker-compose.yml down",
    "infra:logs": "docker compose -f docker-compose.yml logs -f"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
