# React Native + Expo libraries routinely declare peer ranges that no real
# project actually satisfies (e.g. RN 0.81 wants @types/react@^19.1 but the
# transitive virtualized-lists wants something narrower). The whole ecosystem
# is expected to install with legacy resolution mode — Expo CLI does this
# automatically when it spawns npm. Persist it here so plain `npm install`
# in this workspace behaves identically.
legacy-peer-deps=true
