# ─── App ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8088
LOG_LEVEL=debug
SERVICE_NAME=mv-api

# Public base URL the API is reachable at
PUBLIC_BASE_URL=http://localhost:8088

# Tenant — single-tenant Phase 1 (see ADR-010)
DEFAULT_TENANT_ID=000000000000000000000001

# ─── Mongo ──────────────────────────────────────────────────────────────
# Host port 27018 to avoid conflicting with any other local mongo (container internal stays 27017).
MONGO_URI=mongodb://localhost:27018/manhattan_vibes?replicaSet=rs0&directConnection=true
MONGO_MAX_POOL=50

# ─── Redis ──────────────────────────────────────────────────────────────
# Host port 6380 to avoid conflicting with any other local redis.
REDIS_URL=redis://localhost:6380

# ─── JWT (RS256) ────────────────────────────────────────────────────────
# In production these come from KMS / Secrets Manager.
# In dev, generate with:
#   openssl genrsa -out jwt-private.pem 2048
#   openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
# Then paste the PEM contents (newlines escaped as \n) here.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ISSUER=manhattan-vibes
JWT_AUDIENCE=mv-clients
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
JWT_KID=dev-1

# ─── OTP ────────────────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RATE_PER_MIN=3
OTP_RATE_PER_DAY=20
# When true, OTP code is logged at debug level instead of sent via SMS provider.
# NEVER true outside development.
OTP_DEV_MODE=true

# ─── Rate limiting ──────────────────────────────────────────────────────
RATE_LIMIT_ANON_PER_MIN=60
RATE_LIMIT_CUSTOMER_PER_MIN=300
RATE_LIMIT_STAFF_PER_MIN=1000

# ─── CORS ───────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003

# ─── Bcrypt ─────────────────────────────────────────────────────────────
BCRYPT_COST=12
