{
  "name": "@mv/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsup src/main.ts --format esm --target node22 --clean --sourcemap --dts=false",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx src/scripts/seed.ts",
    "smoke": "tsx src/scripts/smoke.ts"
  },
  "dependencies": {
    "@mv/shared-types": "*",
    "@mv/validators": "*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.21.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "mongoose": "^8.8.0",
    "nanoid": "^5.0.7",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "rate-limit-redis": "^4.2.0",
    "rate-limiter-flexible": "^5.0.4",
    "socket.io": "^4.8.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@mv/eslint-config": "*",
    "@mv/tsconfig": "*",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.8.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.13.0",
    "pino-pretty": "^11.3.0",
    "supertest": "^7.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
